 */
function showToast(message, type='success') {
    const toastElement = document.createElement('div');
    toastElement.className = `toast ${type}`;
    toastElement.innerHTML = type === 'error' ?
        `<i class="fa-solid fa-circle-xmark"></i> ${message}` :
